# Core app runtime
PORT=3001
JWT_SECRET=
FINMIND_DATA_FILE=.finmind/data.json
FINMIND_ADMIN_EMAILS=

# Agent mode: "dexter" (recommended), "openrouter", "mock", or "auto"
FINMIND_AGENT_MODE=dexter
OPENROUTER_MODEL=openai/gpt-4o-mini
FINMIND_OPENROUTER_MAX_TOKENS=
FINMIND_DEXTER_PATH=/Users/dev/Documents/PROJECT_LOWLEVEL/dexter
FINMIND_DEXTER_MAX_ITERATIONS=8
FINMIND_DEXTER_FALLBACK_TO_OPENROUTER=true

# Live provider keys
OPENROUTER_API_KEY=
FINANCIAL_DATASETS_API_KEY=
EXASEARCH_API_KEY=
TAVILY_API_KEY=

# Optional production integrations
DATABASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Frontend flags
VITE_SHOW_FEATURE_LAB=false
